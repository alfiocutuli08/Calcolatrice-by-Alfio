<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- AREA DISPLAY: Corrisponde a L1 e L2 dei tuoi blocchi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="2.5"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="10dp"
        >

        <!-- L1: Storico Operazione -->
        <TextView
            android:id="@+id/tvStorico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dot_digital7"
            android:textColor="#888888"
            android:textSize="22sp" />

        <!-- L2: Input Corrente -->
        <TextView
            android:id="@+id/tvInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dot_digital7"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="54sp"
            android:textStyle="bold" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:fontFamily="@font/dot_digital7" >

        <Button
            android:id="@+id/bCA"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="CA"
            android:textAllCaps="false"
            android:textSize="34sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bRadice"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="@string/square_root_symbol"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bPotenza"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="^"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bPercento"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="%"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:fontFamily="@font/dot_digital7" >

        <Button
            android:id="@+id/b7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="7"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/b8"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="8"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/b9"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="9"
            android:textColorLink="#FFFFFF"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bDiviso"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="/"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:fontFamily="@font/dot_digital7" >

        <Button
            android:id="@+id/b4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="4"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/b5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="5"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/b6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="6"
            android:textSize="44sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/bPer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="x"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:fontFamily="@font/dot_digital7" >

        <Button
            android:id="@+id/b1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="1"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/b2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="2"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/b3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="3"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bMeno"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="-"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:fontFamily="@font/dot_digital7" >

        <Button
            android:id="@+id/b0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="0"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bVirgola"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#222222"
            android:fontFamily="@font/dot_digital7"
            android:text="."
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bPiu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#424242"
            android:fontFamily="@font/dot_digital7"
            android:text="+"
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />

        <Button
            android:id="@+id/bUguale"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:layout_weight="1"
            android:backgroundTint="#FF5722"
            android:fontFamily="@font/dot_digital7"
            android:text="="
            android:textSize="44sp"
            android:textStyle="bold"
            app:cornerRadius="100dp" />
    </LinearLayout>

</LinearLayout>
